# S3 configuration placeholders

AWS_REGION=${AWS_REGION:us-east-1}
S3_BUCKET=${S3_BUCKET:}
S3_PREFIX=${S3_PREFIX:}

# Note: AWS credentials should be provided via environment variables or the instance's IAM role.
# The AWS SDK will use the default credential provider chain, including:
# - AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY environment variables
# - {profile} in ~/.aws/credentials
# - IAM role when running on EC2/ECS
